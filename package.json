{
  "name": "strategic-land-intelligence-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:sites": "tsc -b && node scripts/build-sites.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:domain": "vitest run --config vitest.domain.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "typecheck:domain": "tsc --noEmit --project tsconfig.domain.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "leaflet": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-leaflet": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/leaflet": "latest",
    "@types/node": "^22.15.29",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "esbuild": "^0.28.1",
    "jsdom": "latest",
    "typescript": "^5.8.3",
    "vite": "latest",
    "vitest": "^4.1.9"
  }
}
